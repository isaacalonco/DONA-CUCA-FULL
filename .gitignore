# ============================================
#  DONA CUCA — .gitignore
#  Arquivos que NÃO devem ir para hospedagem
#  ou repositório público
# ============================================

# ─── Dependências Node.js ────────────────────
node_modules/
tools/node_modules/

# ─── Ferramentas de desenvolvimento ──────────
tools/
convert-images.js

# ─── Imagens originais (backup local) ────────
assets/img/original/

# ─── Arquivos de sistema do OS ───────────────
.DS_Store          # macOS
Thumbs.db          # Windows
Desktop.ini        # Windows
ehthumbs.db        # Windows

# ─── Logs e temporários ──────────────────────
*.log
*.tmp
*.temp
.cache/

# ─── Variáveis de ambiente ─────
.env
.env.local
.env.production
*.env

# ─── Editores e IDEs ─────────────────────────
.vscode/settings.json
.idea/
*.suo
*.user
*.swp
*.swo
*~

# ─── Build / dist ────────────────────────────
dist/
build/
out/
